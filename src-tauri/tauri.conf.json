{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BuildBook",
  "version": "0.3.142",
  "identifier": "com.buildbook.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BuildBook",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": [
      "../dist"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0MkU4NkJCMzQxRTM2NkQKUldSdE5oNDB1NFl1NUUyaVo1dnFyQTkvMXh4S3JVNEl5LzNyc0loZjh6Z0RPVmUrK1JGamJOVHEK",
      "endpoints": [
        "https://github.com/illerin/BuildBook/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

